{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@hostfunc/sdk": ["./src/index.ts"],
      "@hostfunc/sdk/ai": ["./src/ai/index.ts"],
      "@hostfunc/sdk/agent": ["./src/agent/index.ts"],
      "@hostfunc/sdk/vector": ["./src/vector/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/shim.ts"]
}
