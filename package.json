{
  "name": "hostfunc",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source platform for tiny composable TypeScript functions",
  "license": "AGPL-3.0-only",
  "author": "Matt <you@example.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hostfunc/hostfunc.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@hostfunc/web",
    "dev:docs": "turbo run dev --filter=@hostfunc/docs",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "pnpm --filter=@hostfunc/db db:generate",
    "db:migrate": "pnpm --filter=@hostfunc/db db:migrate",
    "db:push": "pnpm --filter=@hostfunc/db db:push",
    "db:seed": "pnpm --filter=@hostfunc/db db:seed",
    "db:studio": "pnpm --filter=@hostfunc/db db:studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "setup": "pnpm install && docker compose up -d && pnpm build && pnpm db:migrate",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.11",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^22.10.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
